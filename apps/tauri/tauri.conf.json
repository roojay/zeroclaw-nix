{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "ZeroClaw",
  "version": "0.6.4",
  "identifier": "ai.zeroclawlabs.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:42617/_app/",
    "frontendDist": "http://127.0.0.1:42617/_app/"
  },
  "app": {
    "windows": [
      {
        "title": "ZeroClaw",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http: https: ws: wss:; connect-src 'self' http: https: ws: wss:; script-src 'self' 'unsafe-inline' http: https:; style-src 'self' 'unsafe-inline' http: https:; img-src 'self' http: https: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
